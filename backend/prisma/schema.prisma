generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  SIMPLE
  VARIABLE
  COMBO
}

model SubscriptionPlan {
  id String @id @default(uuid()) @db.Uuid

  name String
  code String @unique

  price        Decimal @default(0)
  durationDays Int     @default(30)

  maxUsers  Int @default(5)
  maxStores Int @default(1)

  features Json?

  paddlePriceId String? @map("paddle_price_id") @db.VarChar(100)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Tenant {
  id String @id @default(uuid()) @db.Uuid

  subscriptionPlanId String?          @db.Uuid
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)

  businessName String
  slug         String @unique

  email String? @unique
  phone String?

  logo String?

  subscriptionStatus String @default("trial")

  trialStartsAt DateTime  @default(now())
  trialEndsAt   DateTime?

  subscribedAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]
  users  User[]
  roles  Role[]

  settings Setting[]

  categories Category[]
  brands     Brand[]
  units      Unit[]
  taxes      Tax[]

  products Product[]

  customers Customer[]
  suppliers Supplier[]

  sales     Sale[]
  purchases Purchase[]

  subscriptions Subscription[]

  stockMovements StockMovement[]

  restaurantTables RestaurantTable[]

  expenses          Expense[]
  expenseCategories ExpenseCategory[]

  auditLogs AuditLog[]

  translations Translation[]

  attributes    Attribute[]
  cashRegisters CashRegister[]

  @@map("tenants")
}

model Store {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String
  code String?

  storeType String

  address String?
  city    String?
  state   String?
  country String?
  zipCode String?
  logo String?

  phone String?
  email String?

  currency   String @default("PKR")
  timezone   String @default("Asia/Karachi")
  dateFormat String @default("d-m-Y")

  taxNumber String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings Setting[]

  sales     Sale[]
  purchases Purchase[]

  restaurantTables RestaurantTable[]

  cashRegisters CashRegister[]

  expenses Expense[]

  storeLanguages  StoreLanguage[]
  storeCategories Category[]

  storeBrands           Brand[]
  storeUnits            Unit[]
  storeTaxes            Tax[]
  storeExpenseCategories ExpenseCategory[]
  storeAttributes       Attribute[]

  stockMovements StockMovement[]

  storeUsers    StoreUser[]
  storeProducts StoreProduct[]

  storeCustomers              Customer[]
  storeSuppliers              Supplier[]
  storeProductVariants        ProductVariant[]
  storeProductBatches         ProductBatch[]
  storeProductAttributeValues ProductAttributeValue[]

  @@index([tenantId])
  @@map("stores")
}

model StoreUser {
  id String @id @default(uuid()) @db.Uuid

  storeId String @db.Uuid
  userId  String @db.Uuid

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  role String @default("staff")

  createdAt DateTime @default(now())

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
  @@map("store_users")
}

model User {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?

  email        String @unique
  passwordHash String

  phone  String?
  avatar String?

  lastLoginAt DateTime?

  isSuperAdmin Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  storeUsers     StoreUser[]
  products       Product[]
  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  expenses       Expense[]
  cashRegisters  CashRegister[]
  auditLogs      AuditLog[]

  @@index([tenantId])
  @@map("users")
}

model Role {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id String @id @default(uuid()) @db.Uuid

  name   String  @unique
  module String?

  createdAt DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Category {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  parentId String? @db.Uuid

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  name  String
  image String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  translations CategoryTranslation[]

  @@index([tenantId])
  @@index([storeId])
  @@map("categories")
}

model Brand {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([tenantId])
  @@index([storeId])
  @@map("brands")
}

model Unit {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name      String
  shortName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([tenantId])
  @@index([storeId])
  @@map("units")
}

model Tax {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name String
  rate Decimal

  taxType String @default("percentage")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  products Product[]

  @@index([tenantId])
  @@index([storeId])
  @@map("taxes")
}

model Product {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  categoryId String?   @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  brandId String? @db.Uuid
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  unitId String? @db.Uuid
  unit   Unit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)

  taxId String? @db.Uuid
  tax   Tax?    @relation(fields: [taxId], references: [id], onDelete: SetNull)

  name String

  sku     String?
  barcode String?

  productType ProductType @default(SIMPLE)

  costPrice    Decimal @default(0)
  sellingPrice Decimal @default(0)

  stockQuantity      Decimal @default(0)
  stockAlertQuantity Decimal @default(0)

  hasExpiry Boolean @default(false)
  hasBatch  Boolean @default(false)

  image       String?
  description String?

  isActive Boolean @default(true)

  isGlobal Boolean @default(true)

  createdBy String? @db.Uuid
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]
  batches  ProductBatch[]

  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]

  stockMovements StockMovement[]

  translations ProductTranslation[]

  productAttributes ProductAttributeValue[]
  storeProducts     StoreProduct[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([taxId])
  @@index([barcode])
  @@map("products")
}

model StoreProduct {
  storeId   String @db.Uuid
  productId String @db.Uuid

  stockQuantity Decimal @default(0)
  lowStockAlert Decimal @default(0)

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([storeId, productId])
  @@index([productId])
  @@map("store_products")
}

model ProductVariant {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  variantName String

  sku     String?
  barcode String?

  costPrice    Decimal @default(0)
  sellingPrice Decimal @default(0)

  stockQuantity Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems SaleItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductBatch {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  batchNo String

  manufactureDate DateTime?
  expiryDate      DateTime?

  quantity Decimal @default(0)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_batches")
}

model Sale {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  invoiceNo String

  subtotal Decimal @default(0)
  discount Decimal @default(0)
  tax      Decimal @default(0)
  shipping Decimal @default(0)

  grandTotal Decimal @default(0)

  paymentStatus String @default("pending")
  saleStatus    String @default("completed")

  notes String?

  createdBy String? @db.Uuid
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  items SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, invoiceNo])
  @@index([tenantId])
  @@index([storeId])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  id String @id @default(uuid()) @db.Uuid

  saleId String @db.Uuid
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String? @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productVariantId String?         @db.Uuid
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  quantity Decimal @default(1)

  price    Decimal @default(0)
  discount Decimal @default(0)
  tax      Decimal @default(0)

  total Decimal @default(0)

  createdAt DateTime @default(now())

  @@index([saleId])
  @@map("sale_items")
}

model Purchase {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  supplierId String?   @db.Uuid
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  invoiceNo String?

  subtotal Decimal @default(0)
  discount Decimal @default(0)
  tax      Decimal @default(0)
  shipping Decimal @default(0)

  grandTotal Decimal @default(0)

  paymentStatus  String @default("pending")
  purchaseStatus String @default("received")

  notes String?

  createdBy String? @db.Uuid
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseItem[]

  @@index([tenantId])
  @@map("purchases")
}

model PurchaseItem {
  id String @id @default(uuid()) @db.Uuid

  purchaseId String @db.Uuid
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String? @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  quantity Decimal @default(1)

  costPrice Decimal @default(0)
  tax       Decimal @default(0)
  discount  Decimal @default(0)

  total Decimal @default(0)

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@map("purchase_items")
}

model StockMovement {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productId String @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  movementType String

  quantity Decimal

  referenceType String?
  referenceId   String?

  notes String?

  createdBy String? @db.Uuid
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("stock_movements")
}

model RestaurantTable {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  tableName String

  capacity Int @default(1)

  status String @default("available")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@map("restaurant_tables")
}

model ExpenseCategory {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name String

  createdAt DateTime @default(now())

  expenses Expense[]

  @@index([tenantId])
  @@index([storeId])
  @@map("expense_categories")
}

model Expense {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String?          @db.Uuid
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  amount Decimal

  notes String?

  expenseDate DateTime @default(now())

  createdBy String? @db.Uuid
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("expenses")
}

model CashRegister {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  openingBalance Decimal  @default(0)
  closingBalance Decimal?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  status String @default("open")

  @@map("cash_registers")
}

model Subscription {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  subscriptionPlanId String?          @db.Uuid
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)

  startDate DateTime
  endDate   DateTime

  amount Decimal @default(0)

  paymentStatus String @default("pending")
  status        String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("subscriptions")
}

model Language {
  id String @id @default(uuid()) @db.Uuid

  code       String  @unique
  name       String
  nativeName String?

  isRtl     Boolean @default(false)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())

  translations Translation[]

  productTranslations  ProductTranslation[]
  categoryTranslations CategoryTranslation[]

  storeLanguages StoreLanguage[]

  @@map("languages")
}

model Translation {
  id String @id @default(uuid()) @db.Uuid

  tenantId String? @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  translationGroup String @map("translation_group")
  translationKey   String @map("translation_key")
  translationValue String @map("translation_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, languageId, translationGroup, translationKey])
  @@index([languageId])
  @@index([tenantId])
  @@map("translations")
}

model ProductTranslation {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  name        String
  description String?

  createdAt DateTime @default(now())

  @@unique([productId, languageId])
  @@map("product_translations")
}

model CategoryTranslation {
  id String @id @default(uuid()) @db.Uuid

  categoryId String @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  name String

  createdAt DateTime @default(now())

  @@unique([categoryId, languageId])
  @@map("category_translations")
}

model StoreLanguage {
  id String @id @default(uuid()) @db.Uuid

  storeId String @db.Uuid
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([storeId, languageId])
  @@map("store_languages")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  tenantId String? @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  module String?
  action String?

  recordId String?

  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Attribute {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name String

  createdAt DateTime @default(now())

  values AttributeValue[]

  productAttributes ProductAttributeValue[]

  @@index([tenantId])
  @@index([storeId])
  @@map("attributes")
}

model AttributeValue {
  id String @id @default(uuid()) @db.Uuid

  attributeId String @db.Uuid
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  value String

  createdAt DateTime @default(now())

  productAttributes ProductAttributeValue[]

  @@map("attribute_values")
}

model ProductAttributeValue {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  attributeId String @db.Uuid
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  attributeValueId String         @db.Uuid
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@map("product_attribute_values")
}

model Setting {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  settingKey   String
  settingValue String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, storeId, settingKey])
  @@map("settings")
}

model Customer {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String

  phone String?
  email String?

  address String?
  city    String?
  country String?

  loyaltyPoints Int @default(0) @map("loyalty_points")

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  sales Sale[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("customers")
}

model Supplier {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String

  phone String?
  email String?

  address String?

  storeId String? @db.Uuid
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  purchases Purchase[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

